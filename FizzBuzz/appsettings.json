{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "fizzbuzz",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Keycloak": {
    "Authority": "http://localhost:8081/realms/fizzbuzz",
    "MetadataAddress": "http://localhost:8081/realms/fizzbuzz/.well-known/openid-configuration",
    "Audience": "fizzbuzz-api",
    "RequireHttpsMetadata": false,
    "AuthorizationUrl": "http://localhost:8081/realms/fizzbuzz/protocol/openid-connect/auth",
    "TokenUrl": "http://localhost:8081/realms/fizzbuzz/protocol/openid-connect/token",
    "SwaggerClientId": "fizzbuzz-swagger"
  }
}
