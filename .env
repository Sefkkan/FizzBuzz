# Secrets
# These secrets should not be committed but retrieved from a secured vault (e.g. AWS Secrets Manager).
# However, here we're committing them for the sake of simplifying project onboarding.
# These secrets only work locally and should not be reused in any production environment.
REDIS_PASSWORD=dev_5kQ2pX9wL7mNvR3t

# Keycloak admin console (http://localhost:8081/admin)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Grafana OAuth client secret
# in keycloak/realm-export.json.
GRAFANA_OAUTH_CLIENT_SECRET=dev-grafana-oauth-secret
